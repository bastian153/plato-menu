NODE_ENV=development
PORT=3847
PUBLIC_BASE_URL=http://127.0.0.1:3847
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES=7d
TRUST_PROXY=false

# Demo seed account
PLATO_DEMO_EMAIL=demo@plato.menu
PLATO_DEMO_PASSWORD=demo1234

# SQLite (default) — leave DATABASE_URL empty
# PLATO_DB_PATH=./data/plato.db

# Postgres (production option) — when set, SQLite is not used
# DATABASE_URL=postgres://user:pass@localhost:5432/plato

# Storage: local (default) or s3 (works with AWS S3 or Cloudflare R2)
STORAGE_DRIVER=local
# S3_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET=plato-uploads
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=https://cdn.example.com
# S3_FORCE_PATH_STYLE=true

# SpaceXAI / xAI — menu photo scan (vision) + text extract
# XAI_API_KEY=
# XAI_VISION_MODEL=grok-2-vision-1212
# XAI_MODEL=grok-4.5

# Translation: auto | mymemory | deepl | google
TRANSLATE_PROVIDER=auto
# DEEPL_API_KEY=
# DEEPL_API_URL=https://api-free.deepl.com/v2/translate
# GOOGLE_TRANSLATE_API_KEY=
# Extra glossary terms (comma-separated)
# TRANSLATE_GLOSSARY=birria,al pastor,horchata

# Magic link email (optional — without SMTP, links print to server console)
MAGIC_LINK_EXPIRES_MIN=20
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Plato <noreply@plato.menu>

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://127.0.0.1:3847/api/auth/google/callback

# Rate limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
RATE_LIMIT_AUTH_MAX=40
