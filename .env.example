NODE_ENV=development
PORT=3847
PUBLIC_BASE_URL=http://127.0.0.1:3847
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES=7d
TRUST_PROXY=false

# Demo seed account
PLATO_DEMO_EMAIL=demo@plato.menu
PLATO_DEMO_PASSWORD=demo1234

# SpaceXAI / xAI — menu photo scan (vision) + text extract
# XAI_API_KEY=
XAI_VISION_MODEL=grok-4.5
XAI_MODEL=grok-4.5

# Translation: auto | mymemory | deepl | google
TRANSLATE_PROVIDER=auto

# Rate limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
RATE_LIMIT_AUTH_MAX=40

# Stripe (optional — guest tip / pay)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# Branding for magic-link emails
# PLATO_BRAND_NAME=Plato
# PLATO_BRAND_ACCENT=#e85d04
# PLATO_BRAND_DOMAIN=https://your-domain.com
